# Copy this file to `.env` (same directory) and fill in your values.
# `.env` is gitignored — your secrets never get committed.

# --- Database (Supabase Postgres) ---------------------------------------------
# From your Supabase project: Settings -> Database -> Connection string -> URI.
# Paste it here AS-IS (starting with postgresql://). The app normalizes the
# driver scheme automatically, so you don't need to edit it.
#   e.g. postgresql://postgres.abcd:YOURPASSWORD@aws-0-xx.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- External data credentials (server-side only; never sent to the browser) --
IUCN_API_TOKEN=
INATURALIST_TOKEN=
GBIF_USER=
GBIF_PWD=
GBIF_EMAIL=
